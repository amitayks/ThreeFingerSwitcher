<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>ThreeFingerSwitcher</string>
    <key>CFBundleDisplayName</key>
    <string>Three-Finger Window Switcher</string>
    <key>CFBundleIdentifier</key>
    <string>com.threefingerswitcher.app</string>
    <key>CFBundleExecutable</key>
    <string>ThreeFingerSwitcher</string>
    <key>CFBundleIconFile</key>
    <string>AppIcon</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>0.1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>LSMinimumSystemVersion</key>
    <string>15.0</string>
    <!-- Menu-bar agent: no Dock icon, no main window. -->
    <key>LSUIElement</key>
    <true/>
    <key>NSHumanReadableCopyright</key>
    <string>GPL-3.0. See LICENSE.</string>
    <!-- Shown if macOS ever prompts for Input Monitoring on the multitouch read. -->
    <key>NSInputMonitoringUsageDescription</key>
    <string>Reads raw trackpad touches to detect the three-finger swipe.</string>
    <!-- Shown when an "add to calendar" AI command first creates an event (EventKit, lazy first-use). -->
    <key>NSCalendarsFullAccessUsageDescription</key>
    <string>Creates calendar events from text when you run an "add to calendar" AI command.</string>
    <!-- Shown when an "add to reminders" AI command first creates a reminder (EventKit, lazy first-use). -->
    <key>NSRemindersFullAccessUsageDescription</key>
    <string>Creates reminders from text when you run an "add to reminders" AI command.</string>
    <!-- Shown when a "new contact" AI command first creates a contact card (Contacts, lazy first-use). -->
    <key>NSContactsUsageDescription</key>
    <string>Creates a contact card from text when you run a "new contact" AI command.</string>
</dict>
</plist>
